<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Embed Builder - Hacker Bot</title>
  <link rel="stylesheet" href="/css/dashboard.css">
  <style>
    .layout { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    @media (max-width: 900px) { .layout { grid-template-columns: 1fr; } }
    .form-section { background: var(--bg-secondary); border: 1px solid var(--border-primary); border-radius: var(--radius-lg); padding: 24px; }
    .form-section h3 { margin-bottom: 16px; color: var(--accent); font-size: 1rem; font-weight: 700; }
    .btn-group { display: flex; gap: 10px; margin-top: 20px; }
    .field-row { display: grid; grid-template-columns: 1fr 1fr auto auto; gap: 8px; align-items: end; margin-bottom: 10px; }
    .field-row input[type="checkbox"] { width: auto; margin-bottom: 8px; accent-color: var(--accent); }
    .channel-preview { background: #36393f; border-radius: 12px; overflow: hidden; max-height: 600px; display: flex; flex-direction: column; }
    .channel-header { background: #2f3136; padding: 12px 16px; border-bottom: 1px solid #202225; display: flex; align-items: center; gap: 8px; }
    .channel-header .hash { color: #72767d; font-size: 1.2rem; }
    .channel-header .name { color: #fff; font-weight: 600; font-size: 0.95rem; }
    .messages-container { flex: 1; overflow-y: auto; padding: 16px; max-height: 500px; }
    .messages-container::-webkit-scrollbar { width: 6px; }
    .messages-container::-webkit-scrollbar-track { background: #36393f; }
    .messages-container::-webkit-scrollbar-thumb { background: #202225; border-radius: 3px; }
    .msg { display: flex; gap: 12px; margin-bottom: 16px; padding: 2px 0; }
    .msg:hover { background: #32353b; border-radius: 4px; }
    .msg-avatar { width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0; }
    .msg-body { flex: 1; min-width: 0; }
    .msg-header { display: flex; align-items: baseline; gap: 8px; margin-bottom: 3px; }
    .msg-author { font-weight: 600; font-size: 0.95rem; }
    .msg-author.bot { color: #5865f2; }
    .msg-author.user { color: #e0e0e0; }
    .msg-bot-tag { background: #5865f2; color: #fff; font-size: 0.65rem; padding: 1px 4px; border-radius: 3px; font-weight: 600; }
    .msg-time { color: #72767d; font-size: 0.75rem; }
    .msg-content { color: #dcddde; font-size: 0.95rem; line-height: 1.4; word-wrap: break-word; }
    .msg-content .mention { background: rgba(88,101,242,0.3); color: #dee0fc; padding: 0 2px; border-radius: 3px; }
    .msg-badge { background: #2f3136; padding: 2px 6px; border-radius: 4px; font-size: 0.7rem; color: #888; }
    .msg-embed { background: #2f3136; border-left: 4px solid #5865f2; border-radius: 4px; padding: 10px; margin-top: 6px; max-width: 400px; }
    .msg-embed-title { font-size: 0.85rem; font-weight: 600; color: #fff; margin-bottom: 4px; }
    .msg-embed-desc { font-size: 0.8rem; color: #dcddde; }
    .msg-divider { border: none; border-top: 1px solid #42454a; margin: 8px 0; }
    .no-channel { display: flex; align-items: center; justify-content: center; height: 300px; color: #72767d; font-size: 0.9rem; flex-direction: column; gap: 10px; }
    .no-channel .icon { font-size: 2rem; }
    .preview-box { background: #36393f; border-radius: 8px; padding: 16px; margin-top: 10px; }
    .preview-label { color: #888; font-size: 0.8rem; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px; }
    .discord-embed { background: #2f3136; border-radius: 6px; border-left: 4px solid #5865f2; padding: 12px; }
    .discord-embed .author { display: flex; gap: 8px; align-items: center; margin-bottom: 6px; }
    .discord-embed .author img { width: 20px; height: 20px; border-radius: 50%; }
    .discord-embed .author span { font-size: 0.8rem; font-weight: 600; color: #fff; }
    .discord-embed .title { font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 4px; }
    .discord-embed .description { font-size: 0.85rem; color: #dcddde; line-height: 1.4; margin-bottom: 8px; }
    .discord-embed .fields { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 8px; }
    .discord-embed .field { background: #2f3136; border-radius: 4px; padding: 6px 8px; min-width: 80px; }
    .discord-embed .field.inline { max-width: 30%; flex: unset; }
    .discord-embed .field-name { font-size: 0.75rem; font-weight: 700; color: #fff; margin-bottom: 2px; }
    .discord-embed .field-value { font-size: 0.75rem; color: #dcddde; }
    .discord-embed .thumbnail { float: right; margin-left: 8px; }
    .discord-embed .thumbnail img { width: 60px; height: 60px; border-radius: 4px; }
    .discord-embed .image { margin-top: 8px; }
    .discord-embed .image img { max-width: 100%; border-radius: 4px; }
    .discord-embed .footer { margin-top: 8px; display: flex; gap: 6px; align-items: center; }
    .discord-embed .footer span { font-size: 0.7rem; color: #72767d; }
    .mention-tag { background: var(--bg-tertiary); padding: 4px 10px; border-radius: 4px; font-size: 0.8rem; color: var(--text-primary); display: inline-flex; align-items: center; gap: 6px; border: 1px solid var(--border-primary); }
    .mention-tag .remove { cursor: pointer; color: var(--red); font-weight: bold; }

    #embed-tab .form-section { border-top: 3px solid #5865f2; }
    #text-tab .form-section { border-top: 3px solid #57f287; }
    .text-msg-preview { background: #313338; border-radius: 12px; padding: 16px; margin-top: 12px; }
    .text-msg-preview .msg { display: flex; gap: 12px; align-items: flex-start; }
    .text-msg-preview .msg-avatar { width: 40px; height: 40px; border-radius: 50%; }
    .text-msg-preview .msg-body { flex: 1; }
    .text-msg-preview .msg-header { display: flex; align-items: baseline; gap: 8px; margin-bottom: 4px; }
    .text-msg-preview .msg-author { font-weight: 600; color: #fff; font-size: 0.95rem; }
    .text-msg-preview .msg-time { color: #72767d; font-size: 0.75rem; }
    .text-msg-preview .msg-text { color: #dcddde; font-size: 0.95rem; line-height: 1.5; }
    .text-msg-preview .msg-text .mention { background: rgba(88,101,242,0.3); color: #dee0fc; padding: 0 2px; border-radius: 3px; }
    .text-msg-preview .no-msg { text-align: center; color: #72767d; padding: 20px; font-size: 0.9rem; }
    .char-counter { font-size: 0.75rem; color: var(--text-muted); margin-top: 4px; text-align: right; }
    .char-counter.over { color: var(--red); font-weight: 600; }
    .text-tools { display: flex; gap: 6px; margin-top: 8px; flex-wrap: wrap; }
    .text-tools button { background: var(--bg-tertiary); border: 1px solid var(--border-primary); color: var(--text-secondary); padding: 4px 10px; border-radius: var(--radius-sm); font-size: 0.75rem; cursor: pointer; transition: all 0.15s; }
    .text-tools button:hover { background: var(--accent); color: #000; border-color: var(--accent); }
  </style>
</head>
<body>
  <nav class="nav">
    <a href="/" class="nav-logo"><span class="logo-icon">H</span> Hacker Bot</a>
    <div class="nav-right">
      <a href="/dashboard" class="nav-link">Dashboard</a>
      <a href="/dashboard/guild/<%= guildId %>/embed" class="nav-link active">Embed Builder</a>
      <a href="/dashboard/guild/<%= guildId %>" class="nav-link">Server Control</a>
      <a href="/auth/logout" class="nav-link">Logout</a>
      <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="nav-avatar" alt="">
    </div>
  </nav>

  <div class="container">
    <h1 class="page-title">Embed Builder</h1>
    <p class="page-subtitle">Create and send embeds — preview channel messages live</p>

    <div class="tabs">
      <button class="tab active" onclick="switchTab('embed')">Embed Builder</button>
      <button class="tab" onclick="switchTab('text')">Text Message</button>
    </div>

    <div id="embed-tab" class="layout">
      <div class="form-section">
        <h3>Embed Configuration</h3>

        <div class="form-group">
          <label>Send to Channel</label>
          <select id="channelSelect" onchange="loadChannelMessages()" class="form-select">
            <option value="">Select a channel...</option>
          </select>
        </div>

        <div class="form-group">
          <label>Mention Members / Roles</label>
          <div id="mentionTags" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px;"></div>
          <div style="display:flex;gap:8px;">
            <select id="mentionSelect" class="form-select" style="flex:1;">
              <option value="">Select member or role...</option>
            </select>
            <button type="button" class="btn btn-secondary btn-sm" onclick="addMention()">Tag</button>
          </div>
        </div>

        <div class="form-group">
          <label>Author Name</label>
          <input type="text" id="authorName" placeholder="Author name (optional)" class="form-input">
        </div>
        <div class="form-group">
          <label>Author Icon URL</label>
          <input type="text" id="authorIcon" placeholder="https://example.com/icon.png" class="form-input">
        </div>
        <div class="form-group">
          <label>Title</label>
          <input type="text" id="embedTitle" placeholder="Embed title" class="form-input">
        </div>
        <div class="form-group">
          <label>Description</label>
          <textarea id="embedDescription" placeholder="Embed description" rows="4" class="form-textarea"></textarea>
        </div>
        <div class="form-group">
          <label>Color</label>
          <div class="color-picker">
            <input type="color" id="colorPicker" value="#5865f2" onchange="syncColor(this.value)">
            <input type="text" id="embedColor" value="#5865f2" oninput="syncColorPicker(this.value)" class="form-input" style="flex:1;">
          </div>
        </div>
        <div class="form-group">
          <label>Thumbnail URL</label>
          <input type="text" id="thumbnailUrl" placeholder="https://example.com/thumb.png" class="form-input">
        </div>
        <div class="form-group">
          <label>Image URL</label>
          <input type="text" id="imageUrl" placeholder="https://example.com/image.png" class="form-input">
        </div>
        <div class="form-group">
          <label>Footer Text</label>
          <input type="text" id="footerText" placeholder="Footer text" class="form-input">
        </div>
        <div class="form-group">
          <label>Content (message above embed)</label>
          <textarea id="messageContent" placeholder="Optional text above embed" rows="2" class="form-textarea"></textarea>
        </div>

        <h3 style="margin-top:15px;">Fields</h3>
        <div id="fieldsContainer">
          <div class="field-row">
            <div><label>Name</label><input type="text" class="field-name form-input" placeholder="Field name" oninput="updatePreview()"></div>
            <div><label>Value</label><input type="text" class="field-value form-input" placeholder="Value" oninput="updatePreview()"></div>
            <div><label>Inline</label><input type="checkbox" class="field-inline" onchange="updatePreview()"></div>
            <div><label>&nbsp;</label><button class="btn btn-danger btn-sm" onclick="removeField(this)">X</button></div>
          </div>
        </div>
        <button class="btn btn-secondary btn-sm" onclick="addField()" style="margin-top:8px;">+ Add Field</button>

        <div class="btn-group">
          <button class="btn btn-success" onclick="sendEmbed()">Send Embed</button>
          <button class="btn btn-secondary" onclick="clearForm()">Clear</button>
        </div>
      </div>

      <div>
        <!-- LIVE CHANNEL PREVIEW -->
        <div class="channel-preview" id="channelPreview">
          <div class="channel-header">
            <span class="hash">#</span>
            <span class="name" id="previewChannelName">Select a channel</span>
          </div>
          <div class="messages-container" id="messagesContainer">
            <div class="no-channel">
              <div class="icon">#</div>
              <span>Select a channel to see messages</span>
            </div>
          </div>
        </div>

        <!-- EMBED PREVIEW -->
        <div class="preview-box" style="margin-top:15px;">
          <div class="preview-label">Embed Preview</div>
          <div class="msg" id="embedPreviewMsg" style="display:none;">
            <div class="msg-body">
              <div class="msg-content" id="previewContent" style="display:none;"></div>
              <div class="discord-embed" id="previewEmbed" style="border-left-color:#5865f2;">
                <div class="author" id="previewAuthor" style="display:none;">
                  <img id="previewAuthorIcon" src="" alt="">
                  <span id="previewAuthorName"></span>
                </div>
                <div class="thumbnail" id="previewThumbnail" style="display:none;"><img id="previewThumbnailImg" src="" alt=""></div>
                <div class="title" id="previewTitle" style="display:none;"></div>
                <div class="description" id="previewDescription" style="display:none;"></div>
                <div class="fields" id="previewFields"></div>
                <div class="image" id="previewImage" style="display:none;"><img id="previewImageImg" src="" alt=""></div>
                <div class="footer" id="previewFooter" style="display:none;">
                  <span id="previewFooterText"></span>
                  <span>Today at <span id="previewTime"></span></span>
                </div>
              </div>
            </div>
          </div>
          <div id="noPreviewMsg" class="no-channel" style="height:80px;">
            <span>Fill the form to see preview</span>
          </div>
        </div>
      </div>
    </div>

    <div id="text-tab" style="display:none;">
      <div class="layout">
        <div class="form-section">
          <h3 style="color:#57f287;">Send Text Message</h3>
          <div class="form-group">
            <label>Channel</label>
            <select id="textChannelSelect" onchange="loadTextChannelMessages()" class="form-select">
              <option value="">Select a channel...</option>
            </select>
          </div>
          <div class="form-group">
            <label>Mention Members / Roles</label>
            <div id="textMentionTags" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px;"></div>
            <div style="display:flex;gap:8px;">
              <select id="textMentionSelect" class="form-select" style="flex:1;">
                <option value="">Select member or role...</option>
              </select>
              <button type="button" class="btn btn-secondary btn-sm" onclick="addTextMention()">Tag</button>
            </div>
          </div>
          <div class="form-group">
            <label>Message</label>
            <textarea id="textMessage" placeholder="Type your message... (supports **bold**, *italic*, `code`, ~~strikethrough~~)" rows="5" class="form-textarea" oninput="updateTextPreview();updateCharCount();"></textarea>
            <div id="textCharCount" class="char-counter">0 / 2000</div>
          </div>
          <div class="text-tools">
            <button onclick="wrapText('**','**')" title="Bold">B</button>
            <button onclick="wrapText('*','*')" title="Italic"><i>I</i></button>
            <button onclick="wrapText('`','`')" title="Code">&lt;/&gt;</button>
            <button onclick="wrapText('~~','~~')" title="Strikethrough"><s>S</s></button>
            <button onclick="wrapText('\\n','')" title="Newline">+NL</button>
          </div>
          <div class="btn-group">
            <button class="btn btn-success" onclick="sendText()">Send Message</button>
          </div>
        </div>
        <div>
          <div class="preview-box">
            <div class="preview-label">Live Preview</div>
            <div class="text-msg-preview" id="textPreview">
              <div class="no-msg">Type a message to see preview</div>
            </div>
          </div>

          <div class="channel-preview" style="margin-top:15px;">
            <div class="channel-header">
              <span class="hash">#</span>
              <span class="name" id="textPreviewChannelName">Select a channel</span>
            </div>
            <div class="messages-container" id="textMessagesContainer">
              <div class="no-channel">
                <div class="icon">#</div>
                <span>Select a channel to see messages</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const guildId = '<%= guildId %>';

    function switchTab(tab) {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.getElementById('embed-tab').style.display = tab === 'embed' ? 'grid' : 'none';
      document.getElementById('text-tab').style.display = tab === 'text' ? 'grid' : 'none';
      event.target.classList.add('active');
    }

    function syncColor(v) { document.getElementById('embedColor').value = v; updatePreview(); }
    function syncColorPicker(v) { if (/^#[0-9A-Fa-f]{6}$/.test(v)) document.getElementById('colorPicker').value = v; updatePreview(); }

    function addField() {
      const c = document.getElementById('fieldsContainer');
      const row = document.createElement('div');
      row.className = 'field-row';
      row.innerHTML = `
        <div><input type="text" class="field-name" placeholder="Name" oninput="updatePreview()"></div>
        <div><input type="text" class="field-value" placeholder="Value" oninput="updatePreview()"></div>
        <div><input type="checkbox" class="field-inline" onchange="updatePreview()"></div>
        <div><button class="btn btn-danger btn-sm" onclick="removeField(this)">X</button></div>
      `;
      c.appendChild(row);
    }

    function removeField(btn) {
      const rows = document.querySelectorAll('.field-row');
      if (rows.length <= 1) return;
      btn.closest('.field-row').remove();
      updatePreview();
    }

    function updatePreview() {
      const content = document.getElementById('messageContent').value;
      const authorName = document.getElementById('authorName').value;
      const authorIcon = document.getElementById('authorIcon').value;
      const title = document.getElementById('embedTitle').value;
      const description = document.getElementById('embedDescription').value;
      const color = document.getElementById('embedColor').value || '#5865f2';
      const thumbnailUrl = document.getElementById('thumbnailUrl').value;
      const imageUrl = document.getElementById('imageUrl').value;
      const footerText = document.getElementById('footerText').value;

      const hasData = content || title || description || authorName || thumbnailUrl || imageUrl || footerText;
      const msgEl = document.getElementById('embedPreviewMsg');
      const noEl = document.getElementById('noPreviewMsg');

      if (!hasData) { msgEl.style.display = 'none'; noEl.style.display = 'flex'; return; }
      msgEl.style.display = 'flex'; noEl.style.display = 'none';

      const contentEl = document.getElementById('previewContent');
      if (content) { contentEl.style.display = 'block'; contentEl.textContent = content; } else contentEl.style.display = 'none';

      document.getElementById('previewEmbed').style.borderLeftColor = color;

      const authEl = document.getElementById('previewAuthor');
      if (authorName) { authEl.style.display = 'flex'; document.getElementById('previewAuthorName').textContent = authorName; document.getElementById('previewAuthorIcon').src = authorIcon || ''; } else authEl.style.display = 'none';

      const titleEl = document.getElementById('previewTitle');
      if (title) { titleEl.style.display = 'block'; titleEl.textContent = title; } else titleEl.style.display = 'none';

      const descEl = document.getElementById('previewDescription');
      if (description) { descEl.style.display = 'block'; descEl.textContent = description; } else descEl.style.display = 'none';

      const thumbEl = document.getElementById('previewThumbnail');
      if (thumbnailUrl) { thumbEl.style.display = 'block'; document.getElementById('previewThumbnailImg').src = thumbnailUrl; } else thumbEl.style.display = 'none';

      const imgEl = document.getElementById('previewImage');
      if (imageUrl) { imgEl.style.display = 'block'; document.getElementById('previewImageImg').src = imageUrl; } else imgEl.style.display = 'none';

      const footEl = document.getElementById('previewFooter');
      if (footerText) { footEl.style.display = 'flex'; document.getElementById('previewFooterText').textContent = footerText; } else footEl.style.display = 'none';

      const fieldsEl = document.getElementById('previewFields');
      fieldsEl.innerHTML = '';
      document.querySelectorAll('.field-row').forEach(row => {
        const name = row.querySelector('.field-name').value;
        const value = row.querySelector('.field-value').value;
        const inline = row.querySelector('.field-inline').checked;
        if (name && value) {
          const f = document.createElement('div');
          f.className = 'field' + (inline ? ' inline' : '');
          f.innerHTML = `<div class="field-name">${esc(name)}</div><div class="field-value">${esc(value)}</div>`;
          fieldsEl.appendChild(f);
        }
      });

      const now = new Date();
      document.getElementById('previewTime').textContent = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }

    function esc(t) { const d = document.createElement('div'); d.textContent = t; return d.innerHTML; }

    function getFields() {
      const fields = [];
      document.querySelectorAll('.field-row').forEach(row => {
        const name = row.querySelector('.field-name').value;
        const value = row.querySelector('.field-value').value;
        const inline = row.querySelector('.field-inline').checked;
        if (name && value) fields.push({ name, value, inline });
      });
      return fields;
    }

    // ========== CHANNEL MESSAGES ==========
    async function loadChannels() {
      try {
        const res = await fetch(`/api/guild/${guildId}/text-channels`, { credentials: 'include' });
        const data = await res.json();
        if (data.channels) {
          const sel = document.getElementById('channelSelect');
          const tsel = document.getElementById('textChannelSelect');
          data.channels.forEach(c => {
            sel.innerHTML += `<option value="${c.id}">#${c.name}</option>`;
            tsel.innerHTML += `<option value="${c.id}">#${c.name}</option>`;
          });
        }
      } catch (e) { console.error(e); }

      try {
        const mRes = await fetch(`/api/guild/${guildId}/members`, { credentials: 'include' });
        const mData = await mRes.json();
        const rRes = await fetch(`/api/guild/${guildId}/roles`, { credentials: 'include' });
        const rData = await rRes.json();
        const mSel = document.getElementById('mentionSelect');

        if (mData.members) {
          mData.members.forEach(m => {
            mSel.innerHTML += `<option value="<@${m.id}>" data-type="member">👤 ${m.displayName || m.tag}</option>`;
            const textMentionSel = document.getElementById('textMentionSelect');
            if (textMentionSel) textMentionSel.innerHTML += `<option value="<@${m.id}>" data-type="member">👤 ${m.displayName || m.tag}</option>`;
          });
        }
        if (rData.roles) {
          rData.roles.filter(r => r.name !== '@everyone').forEach(r => {
            mSel.innerHTML += `<option value="<@&${r.id}>" data-type="role">🎭 ${r.name}</option>`;
            const textMentionSel = document.getElementById('textMentionSelect');
            if (textMentionSel) textMentionSel.innerHTML += `<option value="<@&${r.id}>" data-type="role">🎭 ${r.name}</option>`;
          });
        }
        mSel.innerHTML += `<option value="@everyone">📢 @everyone</option>`;
        mSel.innerHTML += `<option value="@here">📢 @here</option>`;
        const textMentionSel = document.getElementById('textMentionSelect');
        if (textMentionSel) {
          textMentionSel.innerHTML += `<option value="@everyone">📢 @everyone</option>`;
          textMentionSel.innerHTML += `<option value="@here">📢 @here</option>`;
        }
      } catch (e) { console.error(e); }
    }

    async function loadChannelMessages() {
      const channelId = document.getElementById('channelSelect').value;
      const container = document.getElementById('messagesContainer');
      const nameEl = document.getElementById('previewChannelName');

      if (!channelId) {
        nameEl.textContent = 'Select a channel';
        container.innerHTML = '<div class="no-channel"><div class="icon">#</div><span>Select a channel to see messages</span></div>';
        return;
      }

      container.innerHTML = '<div class="no-channel"><span>Loading messages...</span></div>';

      try {
        const res = await fetch(`/api/guild/${guildId}/channel/${channelId}/messages`, { credentials: 'include' });
        const data = await res.json();

        if (data.error) {
          container.innerHTML = `<div class="no-channel"><span>${data.error}</span></div>`;
          return;
        }

        nameEl.textContent = data.channelName;
        renderMessages(container, data.messages);
      } catch (e) {
        container.innerHTML = '<div class="no-channel"><span>Failed to load messages</span></div>';
      }
    }

    async function loadTextChannelMessages() {
      const channelId = document.getElementById('textChannelSelect').value;
      const container = document.getElementById('textMessagesContainer');
      const nameEl = document.getElementById('textPreviewChannelName');

      if (!channelId) {
        nameEl.textContent = 'Select a channel';
        container.innerHTML = '<div class="no-channel"><div class="icon">#</div><span>Select a channel to see messages</span></div>';
        return;
      }

      container.innerHTML = '<div class="no-channel"><span>Loading messages...</span></div>';

      try {
        const res = await fetch(`/api/guild/${guildId}/channel/${channelId}/messages`, { credentials: 'include' });
        const data = await res.json();

        if (data.error) {
          container.innerHTML = `<div class="no-channel"><span>${data.error}</span></div>`;
          return;
        }

        nameEl.textContent = data.channelName;
        renderMessages(container, data.messages);
      } catch (e) {
        container.innerHTML = '<div class="no-channel"><span>Failed to load messages</span></div>';
      }
    }

    function renderMessages(container, messages) {
      if (!messages || messages.length === 0) {
        container.innerHTML = '<div class="no-channel"><span>No messages yet</span></div>';
        return;
      }

      container.innerHTML = messages.reverse().map(m => {
        const time = new Date(m.timestamp);
        const timeStr = time.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        const dateStr = time.toLocaleDateString();
        const content = m.content ? formatContent(m.content) : '';
        const embedsInfo = m.embeds > 0 ? `<div class="msg-embed"><div class="msg-embed-title">Embed</div><div class="msg-embed-desc">${m.embeds} embed(s)</div></div>` : '';
        const attachInfo = m.attachments > 0 ? `<div class="msg-badge">${m.attachments} attachment(s)</div>` : '';
        const botTag = m.author.bot ? '<span class="msg-bot-tag">BOT</span>' : '';

        return `
          <div class="msg">
            <img src="${m.author.avatar}" class="msg-avatar" alt="">
            <div class="msg-body">
              <div class="msg-header">
                <span class="msg-author ${m.author.bot ? 'bot' : 'user'}">${esc(m.author.tag)}</span>
                ${botTag}
                <span class="msg-time">${dateStr} ${timeStr}</span>
              </div>
              ${content ? `<div class="msg-content">${content}</div>` : ''}
              ${embedsInfo}
              ${attachInfo}
            </div>
          </div>
          <hr class="msg-divider">
        `;
      }).join('');

      container.scrollTop = container.scrollHeight;
    }

    function formatContent(text) {
      return esc(text)
        .replace(/@everyone/g, '<span class="mention">@everyone</span>')
        .replace(/@here/g, '<span class="mention">@here</span>')
        .replace(/<@!?\d+>/g, match => `<span class="mention">${match}</span>`)
        .replace(/<#\d+>/g, match => `<span class="mention">${match}</span>`)
        .replace(/\n/g, '<br>');
    }

    async function sendEmbed() {
      const channelId = document.getElementById('channelSelect').value;
      if (!channelId) return showToast('Select a channel', 'error');

      const mentionTags = [];
      document.querySelectorAll('#mentionTags .mention-tag').forEach(el => {
        mentionTags.push(el.dataset.value);
      });

      let content = document.getElementById('messageContent').value || '';
      if (mentionTags.length) content = mentionTags.join(' ') + (content ? '\n' + content : '');

      const data = {
        channelId,
        content: content || null,
        title: document.getElementById('embedTitle').value || null,
        description: document.getElementById('embedDescription').value || null,
        color: document.getElementById('embedColor').value || '#5865f2',
        authorName: document.getElementById('authorName').value || null,
        authorIcon: document.getElementById('authorIcon').value || null,
        footerText: document.getElementById('footerText').value || null,
        imageUrl: document.getElementById('imageUrl').value || null,
        thumbnailUrl: document.getElementById('thumbnailUrl').value || null,
        fields: getFields()
      };

      try {
        const res = await fetch(`/api/guild/${guildId}/send-embed`, {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data), credentials: 'include'
        });
        const result = await res.json();
        if (result.success) {
          showToast('Embed sent!', 'success');
          document.getElementById('mentionTags').innerHTML = '';
          setTimeout(() => loadChannelMessages(), 1000);
        } else showToast(result.error, 'error');
      } catch (e) { showToast('Network error', 'error'); }
    }

    async function sendText() {
      const channelId = document.getElementById('textChannelSelect').value;
      const content = document.getElementById('textMessage').value;
      if (!channelId) return showToast('Select a channel', 'error');
      if (!content && !document.getElementById('textMentionTags').children.length) return showToast('Enter a message or add mentions', 'error');

      const mentionTags = [];
      document.querySelectorAll('#textMentionTags .mention-tag').forEach(el => {
        mentionTags.push(el.dataset.value);
      });

      let finalContent = content || '';
      if (mentionTags.length) finalContent = mentionTags.join(' ') + (finalContent ? '\n' + finalContent : '');

      try {
        const res = await fetch(`/api/guild/${guildId}/send-text`, {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ channelId, content: finalContent }), credentials: 'include'
        });
        const result = await res.json();
        if (result.success) {
          showToast('Message sent!', 'success');
          document.getElementById('textMessage').value = '';
          document.getElementById('textMentionTags').innerHTML = '';
          setTimeout(() => loadTextChannelMessages(), 1000);
        } else showToast(result.error, 'error');
      } catch (e) { showToast('Network error', 'error'); }
    }

    function addMention() {
      const sel = document.getElementById('mentionSelect');
      const value = sel.value;
      const text = sel.options[sel.selectedIndex].text;
      if (!value) return;

      const container = document.getElementById('mentionTags');
      const tag = document.createElement('span');
      tag.className = 'mention-tag';
      tag.dataset.value = value;
      tag.style.cssText = 'background:#0f3460;padding:4px 10px;border-radius:4px;font-size:0.8rem;color:#fff;display:inline-flex;align-items:center;gap:6px;';
      tag.innerHTML = `${esc(text)} <span class="remove" onclick="this.parentElement.remove()">X</span>`;
      container.appendChild(tag);
      sel.value = '';
    }

    function addTextMention() {
      const sel = document.getElementById('textMentionSelect');
      const value = sel.value;
      const text = sel.options[sel.selectedIndex].text;
      if (!value) return;

      const container = document.getElementById('textMentionTags');
      const tag = document.createElement('span');
      tag.className = 'mention-tag';
      tag.dataset.value = value;
      tag.innerHTML = `${esc(text)} <span class="remove" onclick="this.parentElement.remove()">X</span>`;
      container.appendChild(tag);
      sel.value = '';
    }

    function clearForm() {
      ['embedTitle','embedDescription','embedColor','authorName','authorIcon','footerText','imageUrl','thumbnailUrl','messageContent'].forEach(id => document.getElementById(id).value = '');
      document.getElementById('colorPicker').value = '#5865f2';
      document.getElementById('fieldsContainer').innerHTML = `
        <div class="field-row">
          <div><input type="text" class="field-name" placeholder="Name" oninput="updatePreview()"></div>
          <div><input type="text" class="field-value" placeholder="Value" oninput="updatePreview()"></div>
          <div><input type="checkbox" class="field-inline" onchange="updatePreview()"></div>
          <div><button class="btn btn-danger btn-sm" onclick="removeField(this)">X</button></div>
        </div>`;
      updatePreview();
    }

    function showToast(msg, type) {
      const t = document.createElement('div');
      t.className = `toast toast-${type}`;
      t.textContent = msg;
      document.body.appendChild(t);
      setTimeout(() => t.remove(), 3000);
    }

    ['embedTitle','embedDescription','embedColor','authorName','authorIcon','footerText','imageUrl','thumbnailUrl','messageContent'].forEach(id => {
      document.getElementById(id).addEventListener('input', updatePreview);
    });

    function updateTextPreview() {
      const text = document.getElementById('textMessage').value;
      const preview = document.getElementById('textPreview');
      if (!text.trim()) {
        preview.innerHTML = '<div class="no-msg">Type a message to see preview</div>';
        return;
      }
      preview.innerHTML = `
        <div class="msg">
          <img src="https://cdn.discordapp.com/avatars/${'<%= user.id %>'}/${'<%= user.avatar %>'}.png" class="msg-avatar" alt="">
          <div class="msg-body">
            <div class="msg-header">
              <span class="msg-author" style="color:#57f287;"><%= user.username || 'You' %></span>
              <span class="msg-time">Today at ${new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'})}</span>
            </div>
            <div class="msg-text">${formatMarkdown(text)}</div>
          </div>
        </div>`;
    }

    function formatMarkdown(text) {
      return esc(text)
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.+?)\*/g, '<em>$1</em>')
        .replace(/~~(.+?)~~/g, '<s>$1</s>')
        .replace(/`(.+?)`/g, '<code style="background:#2f3136;padding:2px 4px;border-radius:3px;font-size:0.9em;">$1</code>')
        .replace(/@everyone/g, '<span class="mention">@everyone</span>')
        .replace(/@here/g, '<span class="mention">@here</span>')
        .replace(/<@!?\d+>/g, match => `<span class="mention">${match}</span>`)
        .replace(/\n/g, '<br>');
    }

    function updateCharCount() {
      const len = document.getElementById('textMessage').value.length;
      const el = document.getElementById('textCharCount');
      el.textContent = `${len} / 2000`;
      el.className = len > 2000 ? 'char-counter over' : 'char-counter';
    }

    function wrapText(before, after) {
      const ta = document.getElementById('textMessage');
      const start = ta.selectionStart;
      const end = ta.selectionEnd;
      const sel = ta.value.substring(start, end);
      const rep = before + (sel || 'text') + after;
      ta.setRangeText(rep, start, end, 'select');
      ta.focus();
      updateTextPreview();
      updateCharCount();
    }

    loadChannels();
  </script>
  <script src="/js/dashboard.js"></script>
</body>
</html>
