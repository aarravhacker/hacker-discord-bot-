<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>404 - Hacker Bot</title>
  <link rel="stylesheet" href="/css/dashboard.css">
  <style>
    .error-page { display: flex; align-items: center; justify-content: center; min-height: 100vh; text-align: center; padding: 20px; }
    .error-page .code { font-size: 8rem; font-weight: 900; background: linear-gradient(135deg, var(--red), var(--orange)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; letter-spacing: -0.04em; line-height: 1; }
    .error-page h2 { font-size: 1.5rem; margin: 12px 0; color: var(--text-primary); }
    .error-page p { color: var(--text-muted); margin-bottom: 32px; max-width: 400px; }
    .error-actions { display: flex; gap: 12px; justify-content: center; }
  </style>
</head>
<body>
  <div class="error-page">
    <div>
      <div class="code">404</div>
      <h2>Page Not Found</h2>
      <p><%= typeof message !== 'undefined' ? message : 'This page does not exist or you don\'t have permission to view it.' %></p>
      <div class="error-actions">
        <a href="/" class="btn btn-primary btn-lg">Go Home</a>
        <a href="javascript:history.back()" class="btn btn-secondary btn-lg">Go Back</a>
      </div>
    </div>
  </div>
</body>
</html>
