    // ========== SECURITY ==========
    async function loadSecurity() {
      try {
        const res = await fetchJSON(`/api/guild/${guildId}/security`);
        const data = res;
        if (data.error) return;

        document.getElementById('tog_antinuke').checked = data.antinuke_enabled;
        document.getElementById('tog_antiraid').checked = data.antiraid_enabled;
        document.getElementById('tog_antibot').checked = data.antibot_enabled;
        document.getElementById('tog_antilink').checked = data.antilink_enabled;
        document.getElementById('tog_antispam').checked = data.antispam_enabled;
        document.getElementById('tog_lockdown').checked = data.lockdown_enabled;

        const anCfg = data.antinuke_config || {};
        document.getElementById('cfg_an_maxChDel').value = anCfg.maxChannelDelete || 3;
        document.getElementById('cfg_an_maxChCreate').value = anCfg.maxChannelCreate || 3;
        document.getElementById('cfg_an_maxRoleDel').value = anCfg.maxRoleDelete || 3;
        document.getElementById('cfg_an_maxRoleCreate').value = anCfg.maxRoleCreate || 3;
        document.getElementById('cfg_an_maxBan').value = anCfg.maxMemberBan || 3;
        document.getElementById('cfg_an_maxKick').value = anCfg.maxMemberKick || 3;
        document.getElementById('cfg_an_timeWindow').value = anCfg.timeWindow || 60000;

        const arCfg = data.antiraid_config || {};
        document.getElementById('cfg_ar_joinThreshold').value = arCfg.joinThreshold || 5;
        document.getElementById('cfg_ar_timeWindow').value = (arCfg.timeWindow || 10000) / 1000;
        document.getElementById('cfg_ar_action').value = arCfg.action || 'kick';

        const abCfg = data.antibot_config || {};
        document.getElementById('cfg_ab_action').value = abCfg.action || 'kick';
        document.getElementById('cfg_ab_allowedBots').value = (abCfg.allowedBots || []).join('\n');

        const alCfg = data.antilink_config || {};
        document.getElementById('cfg_al_action').value = alCfg.action || 'delete';
        document.getElementById('cfg_al_whitelistedDomains').value = (alCfg.whitelistedDomains || []).join('\n');
        document.getElementById('cfg_al_allowedPatterns').value = (alCfg.allowedPatterns || []).join(', ');
        document.getElementById('cfg_al_ignoredChannels').value = (alCfg.ignoredChannels || []).join(', ');
        document.getElementById('cfg_al_ignoredRoles').value = (alCfg.ignoredRoles || []).join(', ');

        const asCfg = data.antispam_config || {};
        document.getElementById('cfg_as_msgLimit').value = asCfg.messageLimit || 5;
        document.getElementById('cfg_as_timeWindow').value = (asCfg.timeWindow || 5000) / 1000;
        document.getElementById('cfg_as_action').value = asCfg.action || 'mute';
        document.getElementById('cfg_as_ignoredChannels').value = (asCfg.ignoredChannels || []).join(', ');
        document.getElementById('cfg_as_ignoredRoles').value = (asCfg.ignoredRoles || []).join(', ');

        const ldCfg = data.lockdown_config || {};
        document.getElementById('cfg_ld_action').value = ldCfg.action || 'readonly';
        document.getElementById('cfg_ld_autoUnlock').value = ldCfg.autoUnlock || 0;
        document.getElementById('cfg_ld_bypassRoles').value = (ldCfg.bypassRoles || []).join(', ');

        displayWhitelist(data.whitelist || []);
        displayBlacklist(data.blacklist || []);

        const anBR = data.antinuke_bypass_role;
        const arBR = data.antiraid_bypass_role;
        const asBR = data.antispam_bypass_role;
        document.getElementById('anBypassRole').textContent = anBR ? `Role ID: ${anBR}` : 'Not created yet — click Auto-Create';
        document.getElementById('arBypassRole').textContent = arBR ? `Role ID: ${arBR}` : 'Not created yet — click Auto-Create';
        document.getElementById('asBypassRole').textContent = asBR ? `Role ID: ${asBR}` : 'Not created yet — click Auto-Create';

        const chRes = await fetchJSON(`/api/guild/${guildId}/channels`);
        const chData = await chRes.json();
        const channelOptions = chData.channels ? chData.channels.filter(c => c.type === 0) : [];
        ['logChannelSelect', 'cfg_ar_alertChannel', 'cfg_ab_alertChannel', 'cfg_ld_alertChannel'].forEach(selId => {
          const sel = document.getElementById(selId);
          if (sel) {
            const currentVal = sel.value || data[selId === 'logChannelSelect' ? 'log_channel' : ''];
            sel.innerHTML = '<option value="">None</option>';
            channelOptions.forEach(c => {
              sel.innerHTML += `<option value="${c.id}" ${currentVal === c.id ? 'selected' : ''}>#${c.name}</option>`;
            });
          }
        });

        loadSecurityIncidents();
        loadSecurityLogs();
        loadTrustData();
        loadSnapshots();
      } catch (e) { console.error(e); }
    }

    async function loadSecurityIncidents() {
      try {
