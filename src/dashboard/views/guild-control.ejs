    async function removeBlacklist(userId) {
      const res = await fetchJSON(`/api/guild/${guildId}/security/blacklist`, {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ userId, action: 'remove' })
      });
      const data = res;
      if (data.success) displayBlacklist(data.blacklist);
    }

    // INIT
    loadChannels();
    loadSecurity();
  </script>
  <script src="/js/dashboard.js"></script>
</body>
</html>
