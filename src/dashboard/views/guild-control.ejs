    async function loadChannelPerms() {
      const channelId = document.getElementById('permChannelSelect').value;
      if (!channelId) { document.getElementById('permEditor').innerHTML = ''; return; }
      try {
        const res = await fetchJSON(`/api/guild/${guildId}/channel/${channelId}/perms`);
        const data = res;
        const editor = document.getElementById('permEditor');
        if (data.error) { editor.innerHTML = `<div class="empty-state">${data.error}</div>`; return; }

        editor.innerHTML = `
          <h4 style="margin:15px 0 10px; color:#fff;"># ${data.channelName} — Permissions</h4>
          <div style="margin-bottom:15px;">
            <label style="color:#aaa;font-size:0.85rem;">Role / Member</label>
            <select id="permTarget" onchange="loadTargetPerms('${channelId}')" style="width:100%;padding:10px;border:1px solid #0f3460;border-radius:8px;background:#1a1a2e;color:#fff;margin-top:5px;">
              ${data.overwrites.map(o => `<option value="${o.id}">${o.name} (${o.type === 0 ? 'Role' : 'Member'})</option>`).join('')}
            </select>
          </div>
          <div id="targetPermsGrid"></div>
          <div style="margin-top:15px;">
            <button class="btn btn-success" onclick="saveChannelPerms('${channelId}')">Save Permissions</button>
          </div>
        `;
        if (data.overwrites.length > 0) loadTargetPerms(channelId, data.overwrites[0].id);
      } catch (e) { console.error(e); }
    }

    async function loadTargetPerms(channelId, targetId) {
      targetId = targetId || document.getElementById('permTarget')?.value;
      if (!targetId) return;
      try {
        const res = await fetchJSON(`/api/guild/${guildId}/channel/${channelId}/perms/${targetId}`);
        const data = res;
        const grid = document.getElementById('targetPermsGrid');
        grid.innerHTML = `<div class="perm-grid">${ALL_PERMS.map(p => {
          const checked = data.perms?.includes(p) ? 'checked' : '';
          return `<div class="perm-item"><input type="checkbox" id="cp_${p.replace(/\s/g,'')}" ${checked}><label for="cp_${p.replace(/\s/g,'')}">${p}</label></div>`;
        }).join('')}</div>`;
      } catch (e) { console.error(e); }
    }

    async function saveChannelPerms(channelId) {
      const targetId = document.getElementById('permTarget')?.value;
      if (!targetId) return;
      const perms = ALL_PERMS.filter(p => document.getElementById(`cp_${p.replace(/\s/g,'')}`)?.checked);
      try {
        const res = await fetchJSON(`/api/guild/${guildId}/channel/${channelId}/perms`, {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ targetId, permissions: perms })
        });
        const data = res;
        showToast(data.message||data.error, data.success?'success':'error');
      } catch (e) { showToast('Failed', 'error'); }
    }

