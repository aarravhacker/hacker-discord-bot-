<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hacker Bot Dashboard</title>
  <link rel="stylesheet" href="/css/dashboard.css">
  <style>
    .hero { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; text-align: center; padding: 20px; background: radial-gradient(ellipse at 50% 0%, #00ff8812 0%, transparent 60%), var(--bg-primary); }
    .hero-badge { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border: 1px solid var(--border-primary); border-radius: 999px; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 24px; background: var(--bg-secondary); }
    .hero-badge .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); animation: pulse 2s infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
    .hero h1 { font-size: 4rem; font-weight: 900; letter-spacing: -0.04em; margin-bottom: 16px; line-height: 1.1; }
    .hero h1 .gradient { background: linear-gradient(135deg, var(--accent) 0%, var(--cyan) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .hero p { font-size: 1.15rem; color: var(--text-muted); margin-bottom: 36px; max-width: 520px; line-height: 1.7; }
    .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
    .features { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; max-width: 960px; margin: 80px auto; padding: 0 24px; }
    .feature { background: var(--bg-card); border: 1px solid var(--border-primary); border-radius: var(--radius-lg); padding: 32px; transition: all var(--transition); position: relative; overflow: hidden; }
    .feature::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, var(--accent), transparent); opacity: 0; transition: opacity var(--transition); }
    .feature:hover { border-color: var(--border-secondary); transform: translateY(-4px); box-shadow: var(--shadow-lg); }
    .feature:hover::before { opacity: 1; }
    .feature .icon { font-size: 2rem; margin-bottom: 16px; }
    .feature h3 { color: var(--text-primary); margin-bottom: 8px; font-size: 1.1rem; font-weight: 700; }
    .feature p { color: var(--text-muted); font-size: 0.9rem; line-height: 1.6; }
    .stats-banner { display: flex; justify-content: center; gap: 48px; padding: 40px 24px; margin-top: 40px; flex-wrap: wrap; }
    .stats-banner .stat { text-align: center; }
    .stats-banner .stat .num { font-size: 2rem; font-weight: 800; color: var(--accent); }
    .stats-banner .stat .label { font-size: 0.75rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 4px; }
    footer { text-align: center; padding: 40px 24px; color: var(--text-dim); border-top: 1px solid var(--border-primary); margin-top: 80px; font-size: 0.85rem; }
  </style>
</head>
<body>
  <nav class="nav">
    <a href="/" class="nav-logo">
      <span class="logo-icon">H</span>
      Hacker Bot
    </a>
    <div class="nav-right">
      <a href="/dashboard" class="nav-link">Dashboard</a>
      <a href="https://discord.gg" target="_blank" class="nav-link">Support</a>
      <% if (user) { %>
        <a href="/dashboard/guilds" class="nav-link">My Servers</a>
        <a href="/auth/logout" class="nav-link">Logout</a>
        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="nav-avatar" alt="avatar">
      <% } else { %>
        <a href="/auth/login" class="nav-btn btn-primary">Login with Discord</a>
      <% } %>
    </div>
  </nav>

  <section class="hero">
    <div class="hero-badge">
      <span class="dot"></span>
      947 commands &middot; 21 event handlers
    </div>
    <h1><span class="gradient">Hacker Bot</span><br>Dashboard</h1>
    <p>Control your Discord server from a powerful web interface. Manage security, moderation, and all bot features in real-time.</p>
    <div class="hero-actions">
      <% if (user) { %>
        <a href="/dashboard/guilds" class="btn btn-primary btn-lg">Go to Dashboard</a>
      <% } else { %>
        <a href="/auth/login" class="btn btn-primary btn-lg">Login with Discord</a>
      <% } %>
      <a href="https://discord.gg" target="_blank" class="btn btn-secondary btn-lg">Join Support Server</a>
    </div>

    <div class="stats-banner">
      <div class="stat"><div class="num">947</div><div class="label">Commands</div></div>
      <div class="stat"><div class="num">23</div><div class="label">Categories</div></div>
      <div class="stat"><div class="num">21</div><div class="label">Event Handlers</div></div>
      <div class="stat"><div class="num">24/7</div><div class="label">Protection</div></div>
    </div>
  </section>

  <div class="features">
    <div class="feature">
      <div class="icon">🛡️</div>
      <h3>Security Control</h3>
      <p>Manage antinuke, antiraid, lockdown, and all security features in real-time with live event feeds.</p>
    </div>
    <div class="feature">
      <div class="icon">👥</div>
      <h3>Member Management</h3>
      <p>View, kick, ban, mute members directly from the dashboard with full moderation controls.</p>
    </div>
    <div class="feature">
      <div class="icon">📋</div>
      <h3>Audit Logs</h3>
      <p>View complete moderation history and track all actions with searchable audit trails.</p>
    </div>
    <div class="feature">
      <div class="icon">⚙️</div>
      <h3>Server Settings</h3>
      <p>Configure welcome, logging, tickets, and all bot settings from one central dashboard.</p>
    </div>
  </div>

  <footer>
    <p>Hacker Bot &copy; 2026 &middot; Powered by Discord.js</p>
  </footer>
  <script src="/js/dashboard.js"></script>
</body>
</html>
